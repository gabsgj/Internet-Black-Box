# ─────────────────────────────────────────────────────────────────────────────
# Internet Black Box — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Neo4j AuraDB ─────────────────────────────────────────────────────────────
# Get these from: https://console.neo4j.io/ → your instance → Connect
SPRING_NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
SPRING_NEO4J_USERNAME=neo4j
SPRING_NEO4J_PASSWORD=<your-password>

# ── NVIDIA NIM (LLM) ─────────────────────────────────────────────────────────
# Get from: https://build.nvidia.com/ → API Keys
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── Sarvam AI (Speech-to-Text + Text-to-Speech) ──────────────────────────────
# Get from: https://app.sarvam.ai/ → API Keys
SARVAM_API_KEY=...

# ── GitHub Integration ────────────────────────────────────────────────────────
# Personal Access Token with: repo, read:org scopes
# Get from: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# ── Slack Integration ─────────────────────────────────────────────────────────
# Create a Slack App at: https://api.slack.com/apps
# Add OAuth scopes: channels:history, channels:read, users:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── Sentry Integration ────────────────────────────────────────────────────────
# Get from: https://sentry.io/ → Project → Settings → Client Keys
SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to use mock data instead of live integrations (dev mode)
USE_MOCK_DATA=false

# ── Frontend (web-dashboard) ──────────────────────────────────────────────────
# URL of the deployed API server (set automatically by Render in production)
VITE_API_URL=http://localhost:8080
