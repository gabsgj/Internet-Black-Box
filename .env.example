# ==============================================================================
# Internet Black Box — Local Environment Variables Template
# ==============================================================================

# --- Neo4j AuraDB / Database Config ---
# URL format: neo4j+s://<dbid>.databases.neo4j.io for AuraDB, or bolt://localhost:7687 for local Docker
SPRING_NEO4J_URI=neo4j+s://your-auradb-instance-id.databases.neo4j.io
SPRING_NEO4J_USERNAME=neo4j
SPRING_NEO4J_PASSWORD=your-auradb-password-here

# --- AI & LLM Engine (NVIDIA NIM) ---
# Used for incident timeline reconstruction and root cause generation
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# --- Voice Engine (Sarvam AI) ---
# Used for Speech-to-Text (STT) and Text-to-Speech (TTS) capabilities
SARVAM_API_KEY=your-sarvam-api-subscription-key

# --- GitHub Data Source Integration ---
# Required for fetching commits, pull requests, and deployment statuses
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_token_here
GITHUB_CLIENT_ID=your-github-oauth-client-id-here
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret-here

# --- Slack Data Source Integration ---
# Monitored channel bots and webhook validation
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your-slack-webhook-signing-secret-here

# --- Sentry Monitoring Integration ---
# DSN for reporting app issues, and auth token for retrieving historical errors
SENTRY_DSN=https://your-sentry-dsn-key@o0.ingest.sentry.io/project-id
SENTRY_AUTH_TOKEN=sntryu_your-sentry-auth-token-here

# --- Ingestion Backend Config ---
# JWT Key used to verify user sessions and authorize dashboards/mobiles
JWT_SECRET=generate-a-secure-256-bit-key-for-jwt-signing-here
PORT=8080
