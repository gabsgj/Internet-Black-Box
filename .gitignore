# ==============================================================================
# Internet Black Box — Master GitIgnore Rules
# ==============================================================================

# --- System & OS Files ---
.DS_Store
.DS_Store?
ehthumbs.db
Icon?
Thumbs.db
.archive/

# --- Environment Secrets (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Node.js & Web Packages (web-dashboard & mobile-app) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Web Frontend Builds (web-dashboard) ---
web-dashboard/dist/
web-dashboard/build/
web-dashboard/.eslintcache

# --- Mobile App Builds & Cache (mobile-app) ---
mobile-app/.expo/
mobile-app/dist/
mobile-app/web-build/
mobile-app/android/
mobile-app/ios/
mobile-app/*.jks
mobile-app/*.p8
mobile-app/*.p12
mobile-app/*.key
mobile-app/*.mobileprovision

# --- Java Backend & Maven (backend) ---
backend/target/
backend/out/
backend/*.class
backend/*.log
backend/bin/

# --- IDEs & Editors ---
.idea/
.vscode/
*.swp
*.swo
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.factorypath
